{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    },
    {
      "src": "backend/src/server.ts",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/src/server.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/v1/automation/cron/process-posts",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/v1/automation/cron/weekly-digest",
      "schedule": "0 9 * * 1"
    }
  ]
}
